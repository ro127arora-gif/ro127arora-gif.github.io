<input type = "text" id = "search_query">
<button py-click="search">Search</button>
<div id="summary"></div>
<py-script>
from pyscript import display, window
import json
from pyodide.http import pyfetch

async def search(event):
    search_query = window.document.getElementByld("search_query")
    query = search_query.value

    if not query:
        display("Try search")
        return

    #Wikipedia API URL
    url = f"https://en.wikipedia.org/api/rest_v1/page/summary/{query}"

    try: 
        response = await pyfetch(url)
        if response.status == 200:
            data = await response.json()
            output = data.get("extract","No detailed info found")
            window.document.getElementByld("summary").innerHTML = output
        
        else:
             window.document.getElementByld("summary").innerHTML = "No results found"

        except Exception as e:
            window.document.getElementByld("summary").innerHTML = "Check your internet settings"
</py-script>
